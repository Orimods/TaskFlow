@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="alert alert-danger">
    <h1 class="h3">Не удалось выполнить запрос</h1>
    <p class="mb-0">Произошла ошибка при обработке данных. Попробуйте повторить действие позже.</p>
</div>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Код запроса:</strong> <code>@Model.RequestId</code>
    </p>
}
