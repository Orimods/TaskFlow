@model TaskFlow.Models.LoginViewModel

@{
    ViewData["Title"] = "Вход в систему";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                <p class="text-muted">Для демонстрации ролевой модели выберите пользователя и войдите в систему.</p>

                <form asp-action="Login" method="post">
                    <input asp-for="ReturnUrl" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="UserId" class="form-label"></label>
                        <select asp-for="UserId" asp-items="ViewBag.Users" class="form-select">
                            <option value="">Выберите пользователя</option>
                        </select>
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Войти</button>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
