@model IEnumerable<TaskFlowApp.Models.Task>

@{
    ViewData["Title"] = "Список задач";
    string ToggleSort(string column) => ViewBag.Sort == column ? $"{column}_desc" : column;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">Обычный пользователь видит только свои задачи.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Создать задачу</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-3">
        <label class="form-label" for="search">Поиск</label>
        <input id="search" name="search" value="@ViewBag.Search" class="form-control" placeholder="Название, описание, категория" />
    </div>
    <div class="col-md-2">
        <label class="form-label" for="status">Статус</label>
        <select id="status" name="status" asp-items="ViewBag.Statuses" class="form-select">
            <option value="">Все статусы</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label" for="categoryId">Категория</label>
        <select id="categoryId" name="categoryId" asp-items="ViewBag.Categories" class="form-select">
            <option value="">Все категории</option>
        </select>
    </div>
    @if (ViewBag.CanFilterUsers == true)
    {
        <div class="col-md-2">
            <label class="form-label" for="userId">Пользователь</label>
            <select id="userId" name="userId" asp-items="ViewBag.Users" class="form-select">
                <option value="">Все пользователи</option>
            </select>
        </div>
    }
    <div class="col-md-auto">
        <button type="submit" class="btn btn-primary">Применить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Сбросить</a>
    </div>
</form>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status" asp-route-categoryId="@ViewBag.CategoryId" asp-route-userId="@ViewBag.UserId" asp-route-sort="@ToggleSort("title")">Название</a></th>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status" asp-route-categoryId="@ViewBag.CategoryId" asp-route-userId="@ViewBag.UserId" asp-route-sort="@ToggleSort("deadline")">Срок</a></th>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status" asp-route-categoryId="@ViewBag.CategoryId" asp-route-userId="@ViewBag.UserId" asp-route-sort="@ToggleSort("status")">Статус</a></th>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status" asp-route-categoryId="@ViewBag.CategoryId" asp-route-userId="@ViewBag.UserId" asp-route-sort="@ToggleSort("category")">Категория</a></th>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status" asp-route-categoryId="@ViewBag.CategoryId" asp-route-userId="@ViewBag.UserId" asp-route-sort="@ToggleSort("user")">Пользователь</a></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var task in Model)
    {
        <tr>
            <td>
                <div class="fw-semibold">@task.Title</div>
                <div class="text-muted small">@task.Description</div>
            </td>
            <td>@task.Deadline.ToString("dd.MM.yyyy")</td>
            <td>@task.Status</td>
            <td>@(task.Category?.Name ?? "Без категории")</td>
            <td>@task.User.FullName</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@task.Id">Открыть</a> |
                <a asp-action="Edit" asp-route-id="@task.Id">Изменить</a> |
                <a asp-action="Delete" asp-route-id="@task.Id">Удалить</a>
            </td>
        </tr>
    }
    @if (!Model.Any())
    {
        <tr>
            <td colspan="6" class="text-center text-muted">Задачи не найдены.</td>
        </tr>
    }
    </tbody>
</table>
