@model TaskFlowApp.Models.Task

@{
    ViewData["Title"] = "Карточка задачи";
}

<h1>@ViewData["Title"]</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <h2 class="h4">@Model.Title</h2>
        <dl class="row mb-0">
            <dt class="col-sm-3">Описание</dt>
            <dd class="col-sm-9">@Model.Description</dd>
            <dt class="col-sm-3">Срок</dt>
            <dd class="col-sm-9">@Model.Deadline.ToString("dd.MM.yyyy")</dd>
            <dt class="col-sm-3">Статус</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Категория</dt>
            <dd class="col-sm-9">@(Model.Category?.Name ?? "Без категории")</dd>
            <dt class="col-sm-3">Пользователь</dt>
            <dd class="col-sm-9">@Model.User.FullName</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редактировать</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
</div>
