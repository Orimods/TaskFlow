@model TaskFlowApp.Models.Task

@{
    ViewData["Title"] = "Delete Task";
}

<h1>@ViewData["Title"]</h1>

<h3>Are you sure you want to delete this task?</h3>

<div>
    <h4>Title: @Model.Title</h4>
    <p>Description: @Model.Description</p>
    <p>Deadline: @Model.Deadline</p>
    <p>Status: @Model.Status</p>
    <p>Category: @Model.Category.Name</p>
    <p>User: @Model.User.FullName</p>
</div>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="@Url.Action("Index", "Task")" class="btn btn-secondary">Cancel</a>
</form>
