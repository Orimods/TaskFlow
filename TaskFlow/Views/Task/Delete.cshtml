@model TaskFlowApp.Models.Task

@{
    ViewData["Title"] = "Удаление задачи";
}

<h1>@ViewData["Title"]</h1>
<p class="text-danger">Подтвердите удаление записи.</p>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div><strong>Название:</strong> @Model.Title</div>
        <div><strong>Статус:</strong> @Model.Status</div>
        <div><strong>Категория:</strong> @(Model.Category?.Name ?? "Без категории")</div>
        <div><strong>Пользователь:</strong> @Model.User.FullName</div>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
</form>
