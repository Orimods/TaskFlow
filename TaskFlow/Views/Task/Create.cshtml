@model TaskFlowApp.Models.Task

@{
    ViewData["Title"] = "Создание задачи";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="Create" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-12">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Deadline" class="form-label"></label>
        <input asp-for="Deadline" class="form-control" type="date" />
        <span asp-validation-for="Deadline" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
            <option value="">Без категории</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>
    @if (ViewBag.CanAssignUsers == true)
    {
        <div class="col-md-6">
            <label asp-for="UserId" class="form-label"></label>
            <select asp-for="UserId" asp-items="ViewBag.UserId" class="form-select"></select>
            <span asp-validation-for="UserId" class="text-danger"></span>
        </div>
    }
    else
    {
        <input asp-for="UserId" type="hidden" />
    }
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
