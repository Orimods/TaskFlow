@model TaskFlowApp.Models.Category

@{
    ViewData["Title"] = "Удаление категории";
}

<h1>@ViewData["Title"]</h1>
<p>После удаления связанные задачи останутся в системе без категории.</p>
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div><strong>Название:</strong> @Model.Name</div>
        <div><strong>Связанных задач:</strong> @Model.Tasks.Count</div>
    </div>
</div>
<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
</form>
