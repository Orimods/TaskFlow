@model IEnumerable<TaskFlowApp.Models.Category>
@using TaskFlow.Security

@{
    ViewData["Title"] = "Категории";
    string ToggleSort(string column) => ViewBag.Sort == column ? $"{column}_desc" : column;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    @if (User.IsInRole(AppRoles.Manager) || User.IsInRole(AppRoles.Admin))
    {
        <a asp-action="Create" class="btn btn-primary">Создать категорию</a>
    }
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label class="form-label" for="search">Поиск</label>
        <input id="search" name="search" value="@ViewBag.Search" class="form-control" placeholder="Название категории" />
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-primary">Найти</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Сбросить</a>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sort="@ToggleSort("name")">Название</a></th>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-sort="@ToggleSort("tasks")">Количество задач</a></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Tasks.Count</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id">Открыть</a>
                @if (User.IsInRole(AppRoles.Manager) || User.IsInRole(AppRoles.Admin))
                {
                    <text> | </text><a asp-action="Edit" asp-route-id="@item.Id">Изменить</a><text> | </text><a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                }
            </td>
        </tr>
    }
    @if (!Model.Any())
    {
        <tr>
            <td colspan="3" class="text-center text-muted">Категории не найдены.</td>
        </tr>
    }
    </tbody>
</table>
