@model TaskFlowApp.Models.Category
@using TaskFlow.Security

@{
    ViewData["Title"] = "Категория";
}

<h1>@Model.Name</h1>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <h2 class="h5">Связанные задачи</h2>
        @if (Model.Tasks.Any())
        {
            <ul class="mb-0">
            @foreach (var task in Model.Tasks)
            {
                <li>@task.Title - @task.User.FullName</li>
            }
            </ul>
        }
        else
        {
            <p class="mb-0 text-muted">У этой категории пока нет задач.</p>
        }
    </div>
</div>

<div>
    @if (User.IsInRole(AppRoles.Manager) || User.IsInRole(AppRoles.Admin))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редактировать</a>
    }
    <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
</div>
