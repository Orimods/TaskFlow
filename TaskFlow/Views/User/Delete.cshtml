@model TaskFlowApp.Models.User

@{
    ViewData["Title"] = "Удаление пользователя";
}

<h1>@ViewData["Title"]</h1>
<p class="text-danger">Удаление пользователя приведёт к удалению его задач.</p>
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div><strong>ФИО:</strong> @Model.FullName</div>
        <div><strong>Логин:</strong> @Model.UserName</div>
        <div><strong>Роль:</strong> @Model.Role</div>
        <div><strong>Задач:</strong> @Model.Tasks.Count</div>
    </div>
</div>
<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
</form>
