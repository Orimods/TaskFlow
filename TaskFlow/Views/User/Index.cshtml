@model IEnumerable<TaskFlowApp.Models.User>

@{
    ViewData["Title"] = "Пользователи";
    string ToggleSort(string column) => ViewBag.Sort == column ? $"{column}_desc" : column;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-primary">Создать пользователя</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label class="form-label" for="search">Поиск</label>
        <input id="search" name="search" value="@ViewBag.Search" class="form-control" placeholder="ФИО или логин" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="role">Роль</label>
        <select id="role" name="role" asp-items="ViewBag.Roles" class="form-select">
            <option value="">Все роли</option>
        </select>
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-primary">Применить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Сбросить</a>
    </div>
</form>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-role="@ViewBag.Role" asp-route-sort="@ToggleSort("name")">ФИО</a></th>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-role="@ViewBag.Role" asp-route-sort="@ToggleSort("login")">Логин</a></th>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-role="@ViewBag.Role" asp-route-sort="@ToggleSort("role")">Роль</a></th>
            <th><a asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-role="@ViewBag.Role" asp-route-sort="@ToggleSort("tasks")">Задач</a></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FullName</td>
            <td>@item.UserName</td>
            <td>@item.Role</td>
            <td>@item.Tasks.Count</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@item.Id">Открыть</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
            </td>
        </tr>
    }
    @if (!Model.Any())
    {
        <tr>
            <td colspan="5" class="text-center text-muted">Пользователи не найдены.</td>
        </tr>
    }
    </tbody>
</table>
