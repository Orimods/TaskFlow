@model TaskFlowApp.Models.User

@{
    ViewData["Title"] = "Пользователь";
}

<h1>@Model.FullName</h1>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Логин</dt>
            <dd class="col-sm-9">@Model.UserName</dd>
            <dt class="col-sm-3">Роль</dt>
            <dd class="col-sm-9">@Model.Role</dd>
            <dt class="col-sm-3">Дата регистрации</dt>
            <dd class="col-sm-9">@Model.RegisteredAt.ToString("dd.MM.yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <h2 class="h5">Задачи пользователя</h2>
        @if (Model.Tasks.Any())
        {
            <ul class="mb-0">
            @foreach (var task in Model.Tasks)
            {
                <li>@task.Title (@(task.Category?.Name ?? "Без категории"))</li>
            }
            </ul>
        }
        else
        {
            <p class="mb-0 text-muted">У пользователя пока нет задач.</p>
        }
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редактировать</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
</div>
