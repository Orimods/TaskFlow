@model TaskFlowApp.Models.User

@{
    ViewData["Title"] = "Редактирование пользователя";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="Edit" method="post" class="row g-3">
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="UserName" class="form-label"></label>
        <input asp-for="UserName" class="form-control" />
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Role" class="form-label"></label>
        <select asp-for="Role" asp-items="ViewBag.Role" class="form-select"></select>
        <span asp-validation-for="Role" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="RegisteredAt" class="form-label"></label>
        <input asp-for="RegisteredAt" class="form-control" />
        <span asp-validation-for="RegisteredAt" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
